<?xml version="1.0" ?>
<!-- Test world with BOX, CYLINDER, and SPHERE targets within 1 m of the nozzle.
     Nozzle spawns at x=0, z=0.2; nozzle tip at x≈0.12, z≈0.3, pointing +X.
     All targets are at x=1.1 so they are within cone_max_range=1.0 m. -->
<sdf version="1.9">
  <world name="test_all_geometry">

    <plugin filename="gz-sim-physics-system"   name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-sensors-system"   name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin filename="gz-sim-particle-emitter-system" name="gz::sim::systems::ParticleEmitter"/>

    <physics name="1ms" type="dart">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <dart><collision_detector>bullet</collision_detector></dart>
    </physics>

    <scene>
      <ambient>0.4 0.4 0.4 1</ambient>
      <background>0.7 0.7 0.8 1</background>
      <shadows>true</shadows>
    </scene>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- Ground plane -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><plane><normal>0 0 1</normal><size>20 20</size></plane></geometry>
        </collision>
        <visual name="visual">
          <geometry><plane><normal>0 0 1</normal><size>20 20</size></plane></geometry>
          <material><ambient>0.8 0.8 0.8 1</ambient><diffuse>0.8 0.8 0.8 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- BOX target — flat white panel facing the nozzle (+X face toward x=0) -->
    <model name="box_target">
      <static>true</static>
      <pose>1.1 0 0.3 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.05 0.8 0.8</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.05 0.8 0.8</size></box></geometry>
          <material>
            <ambient>0.95 0.95 0.95 1</ambient>
            <diffuse>0.95 0.95 0.95 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- CYLINDER target — vertical cylinder beside the box (+Y offset).
         Rotated 90° around Y so the curved barrel faces the nozzle. -->
    <model name="cylinder_target">
      <static>true</static>
      <pose>1.1 0.55 0.3 0 1.5708 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><cylinder><radius>0.2</radius><length>0.5</length></cylinder></geometry>
        </collision>
        <visual name="visual">
          <geometry><cylinder><radius>0.2</radius><length>0.5</length></cylinder></geometry>
          <material>
            <ambient>0.8 0.8 1.0 1</ambient>
            <diffuse>0.8 0.8 1.0 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- SPHERE target — on the -Y side of the box -->
    <model name="sphere_target">
      <static>true</static>
      <pose>1.1 -0.55 0.3 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><sphere><radius>0.25</radius></sphere></geometry>
        </collision>
        <visual name="visual">
          <geometry><sphere><radius>0.25</radius></sphere></geometry>
          <material>
            <ambient>1.0 0.85 0.85 1</ambient>
            <diffuse>1.0 0.85 0.85 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

  </world>
</sdf>
